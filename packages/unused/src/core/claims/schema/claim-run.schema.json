{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unused.dev/schema/claim-run.schema.json",
  "title": "unused claim run",
  "description": "The --json output contract (PRD §4). Hand-authored mirror of packages/unused/src/core/claims/types.ts — keep in lockstep.",
  "type": "object",
  "required": ["schemaVersion", "tool", "run", "claims", "summary"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "ADR 0006 semver policy."
    },
    "tool": { "$ref": "#/$defs/tool" },
    "run": { "$ref": "#/$defs/run" },
    "claims": {
      "type": "array",
      "items": { "$ref": "#/$defs/claim" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },

    "run": {
      "type": "object",
      "required": ["root", "configHash", "startedAt", "durationMs"],
      "additionalProperties": false,
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "commit": {
          "type": "string",
          "minLength": 1,
          "description": "Absent when analysis doesn't happen inside a git repo with a resolvable HEAD."
        },
        "configHash": { "type": "string", "minLength": 1 },
        "startedAt": { "type": "string", "format": "date-time" },
        "durationMs": { "type": "integer", "minimum": 0 }
      }
    },

    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "CLOSED enum (ADR 0006)."
    },

    "evidenceType": {
      "type": "string",
      "minLength": 1,
      "description": "OPEN enum (ADR 0006): static-reachability | test-only | cross-boundary | runtime | human-usage are the values the v1 OSS analyzer knows about (runtime and human-usage are RESERVED, never emitted by v1); consumers must tolerate unknown values here, so this is intentionally not constrained to a closed `enum`."
    },

    "span": {
      "type": "array",
      "description": "Inclusive 1-based [startLine, endLine].",
      "prefixItems": [{ "type": "integer", "minimum": 1 }, { "type": "integer", "minimum": 1 }],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },

    "loc": {
      "type": "object",
      "required": ["file", "span"],
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1,
          "description": "POSIX-style, repo-relative."
        },
        "span": { "$ref": "#/$defs/span" },
        "package": {
          "type": "string",
          "minLength": 1,
          "description": "Workspace/package name in a monorepo."
        }
      }
    },

    "evidenceWindow": {
      "type": "object",
      "required": ["start", "end"],
      "additionalProperties": false,
      "properties": {
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" }
      }
    },

    "evidence": {
      "type": "object",
      "required": ["type", "detail", "source"],
      "additionalProperties": false,
      "properties": {
        "type": { "$ref": "#/$defs/evidenceType" },
        "detail": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "window": { "$ref": "#/$defs/evidenceWindow" }
      }
    },

    "evidenceList": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence" }
    },

    "provenance": {
      "type": "object",
      "required": ["analyzer", "version", "generatedAt"],
      "additionalProperties": false,
      "properties": {
        "analyzer": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "generatedAt": { "type": "string", "format": "date-time" }
      }
    },

    "suppression": {
      "type": "object",
      "required": ["reason"],
      "additionalProperties": false,
      "properties": {
        "reason": { "type": "string", "minLength": 1 }
      }
    },

    "claimId": {
      "type": "string",
      "pattern": "^(exp|fil|dep|end|tst)_[0-9a-f]{16}$",
      "description": "ADR 0006: <prefix>_<first 16 hex of SHA-256(canonical subject string)>."
    },

    "exportFileDependencySubject": {
      "type": "object",
      "required": ["kind", "name", "loc"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["export", "file", "dependency"] },
        "name": { "type": "string", "minLength": 1 },
        "loc": { "$ref": "#/$defs/loc" }
      }
    },

    "endpointSubject": {
      "type": "object",
      "required": ["kind", "name", "loc", "protocol"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "endpoint" },
        "name": { "type": "string", "minLength": 1 },
        "loc": { "$ref": "#/$defs/loc" },
        "protocol": { "type": "string", "enum": ["http", "trpc", "graphql"] },
        "method": {
          "type": "string",
          "minLength": 1,
          "description": "Present when protocol is 'http'; part of claim identity (ADR 0006)."
        }
      }
    },

    "testSubject": {
      "type": "object",
      "required": ["kind", "name", "loc"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "test" },
        "name": { "type": "string", "minLength": 1 },
        "loc": { "$ref": "#/$defs/loc" }
      }
    },

    "claim": {
      "description": "The kind -> verdict binding (PRD §4, 'enforced rule, not convention') is encoded as one oneOf branch per subject kind, each pinning its allowed verdict(s).",
      "oneOf": [
        { "$ref": "#/$defs/exportFileDependencyClaim" },
        { "$ref": "#/$defs/endpointClaim" },
        { "$ref": "#/$defs/testClaim" }
      ]
    },

    "exportFileDependencyClaim": {
      "type": "object",
      "required": ["id", "subject", "verdict", "confidence", "evidence", "provenance"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/claimId" },
        "subject": { "$ref": "#/$defs/exportFileDependencySubject" },
        "verdict": {
          "type": "string",
          "enum": ["unused", "test-only"],
          "description": "export/file/dependency subjects take unused or test-only (PRD §4)."
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence": { "$ref": "#/$defs/evidenceList" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "suppression": { "$ref": "#/$defs/suppression" }
      }
    },

    "endpointClaim": {
      "type": "object",
      "required": ["id", "subject", "verdict", "confidence", "evidence", "provenance"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/claimId" },
        "subject": { "$ref": "#/$defs/endpointSubject" },
        "verdict": {
          "const": "unconsumed-endpoint",
          "description": "endpoint subjects always take unconsumed-endpoint (PRD §4)."
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence": { "$ref": "#/$defs/evidenceList" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "suppression": { "$ref": "#/$defs/suppression" }
      }
    },

    "testClaim": {
      "type": "object",
      "required": ["id", "subject", "verdict", "confidence", "evidence", "provenance"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/claimId" },
        "subject": { "$ref": "#/$defs/testSubject" },
        "verdict": {
          "const": "test-only",
          "description": "test subjects take test-only — a zombie test (PRD §4)."
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "evidence": { "$ref": "#/$defs/evidenceList" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "suppression": { "$ref": "#/$defs/suppression" }
      }
    },

    "summary": {
      "type": "object",
      "required": ["byKind", "byConfidence", "estDeletableLoc"],
      "additionalProperties": false,
      "properties": {
        "byKind": {
          "type": "object",
          "required": ["export", "file", "dependency", "endpoint", "test"],
          "additionalProperties": false,
          "properties": {
            "export": { "type": "integer", "minimum": 0 },
            "file": { "type": "integer", "minimum": 0 },
            "dependency": { "type": "integer", "minimum": 0 },
            "endpoint": { "type": "integer", "minimum": 0 },
            "test": { "type": "integer", "minimum": 0 }
          }
        },
        "byConfidence": {
          "type": "object",
          "required": ["high", "medium", "low"],
          "additionalProperties": false,
          "properties": {
            "high": { "type": "integer", "minimum": 0 },
            "medium": { "type": "integer", "minimum": 0 },
            "low": { "type": "integer", "minimum": 0 }
          }
        },
        "estDeletableLoc": {
          "type": "integer",
          "minimum": 0,
          "description": "PROVISIONAL in v1 M1 — no overlap dedup (phasing.md T3.4 owns the real computation)."
        }
      }
    }
  }
}
